{
  "expo": {
    "name": "Set Volei - Hub",
    "slug": "Set Volei - Hub",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/set_icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/set_icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Precisamos da sua localização para mostrar o mapa e unidades próximas."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/set_icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": ["ACCESS_FINE_LOCATION"]
    },
    "web": {
      "favicon": "./assets/set_icon.png"
    },
    "plugins": [
      "expo-router"
    ]
  }
}
